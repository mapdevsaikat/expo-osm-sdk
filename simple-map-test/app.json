{
  "expo": {
    "name": "Expo OSM Demo",
    "slug": "expo-osm-demo",
    "owner": "theaquaporter",
    "version": "1.3.0",
    "description": "Official demo app for expo-osm-sdk — explore markers, shapes, routes, live GPS tracking, and OpenStreetMap tile styles on a native MapLibre-powered map.",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#9C1AFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mapdevsaikat.expoosmdemo",
      "buildNumber": "3"
    },
    "android": {
      "package": "com.mapdevsaikat.expoosmdemo",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#9C1AFF"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-osm-sdk/plugin",
        {
          "locationWhenInUseDescription": "This demo shows your current position as a blue dot on the map and lets you re-center the camera on it. Your location is only used on-device and is never transmitted or stored anywhere.",
          "enableTrackExport": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ab18db9b-7707-4703-a986-5cb45e68b399"
      }
    }
  }
}
